<Window x:Class="LinearCutOptimization.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LinearCutOptimization.Wpf.Views"
        Title="Linear Cut Optimization (WPF)" Width="1600" Height="950"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Источник данных" FontSize="16" FontWeight="SemiBold"/>

                <Button Content="Открыть .xlsx" Command="{Binding OpenFileCommand}" Margin="0,8,0,0"/>

                <TextBlock Text="Лист:" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding SheetNames}"
                          SelectedItem="{Binding SelectedSheet, Mode=TwoWay}"
                          MinHeight="32"/>

                <TextBlock Text="Роли столбцов" Margin="0,16,0,6" FontSize="16" FontWeight="SemiBold"/>
                <views:ColumnRolesGrid />

                <TextBlock Text="Пресеты" Margin="0,16,0,6" FontSize="16" FontWeight="SemiBold"/>
                <DataGrid ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="False"
                          MinHeight="160"/>

                <TextBlock Text="Склад (Stock)" Margin="0,16,0,6" FontSize="16" FontWeight="SemiBold"/>
                <DataGrid ItemsSource="{Binding Stocks}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="True"
                          MinHeight="160"/>

                <TextBlock Text="Ручной раскрой" Margin="0,16,0,6" FontSize="16" FontWeight="SemiBold"/>
                <DataGrid ItemsSource="{Binding ManualCuts}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="True"
                          MinHeight="240"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Загрузить старый раскрой"
                            Command="{Binding ImportProjectCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Сохранить проект (Excel)"
                            Command="{Binding ExportProjectCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Входные данные (после фильтра)" Grid.Row="0">
                <DataGrid ItemsSource="{Binding GridInputView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"/>
            </GroupBox>

            <GroupBox Header="Результаты" Grid.Row="2">
                <DockPanel LastChildFill="True">
                    <Button Content="Пересчитать"
                            Command="{Binding RunOptimizationCommand}"
                            DockPanel.Dock="Top"
                            Margin="0,0,0,8"/>
                    <TabControl ItemsSource="{Binding ResultTabs}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Header}"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DataGrid ItemsSource="{Binding ResultView}"
                                              IsReadOnly="True"
                                              AutoGenerateColumns="True"/>
                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             Text="{Binding Summary}"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="#FFF2F2F2"
                                             Padding="8"
                                             FontFamily="Consolas"/>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </DockPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>