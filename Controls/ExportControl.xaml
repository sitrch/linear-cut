<UserControl x:Class="LinearCutWpf.Controls.ExportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnExportRaskroj" Content="Раскрой" Padding="10,5" Margin="0,0,10,0" Click="BtnExportRaskroj_Click"/>
            <TextBlock Text="Коэфф. высоты:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtVisualHeightCoef" Width="50" VerticalAlignment="Center" Margin="0,0,15,0" TextChanged="txtVisualHeightCoef_TextChanged"/>
            <Button x:Name="btnExportMaterials" Content="Материалы" Padding="10,5" Margin="0,0,10,0" Click="BtnExportMaterials_Click"/>
        </StackPanel>

        <!-- Таблица для выбора артикулов на выгрузку -->
        <DataGrid x:Name="dgExportData" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Background="White" HeadersVisibility="Column"
                  PreviewKeyDown="dgExportData_PreviewKeyDown">
            <DataGrid.Resources>
                <Style x:Key="ManualCutCellStyle" TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsManualCut}" Value="True">
                            <Setter Property="Background" Value="#FFF8E1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="100">
                    <DataGridCheckBoxColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkSelectAll" Content="Сохранить" IsChecked="True" Click="chkSelectAll_Click"/>
                        </StackPanel>
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" IsReadOnly="True" Width="150" ElementStyle="{StaticResource ManualCutCellStyle}"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" IsReadOnly="True" Width="200" ElementStyle="{StaticResource ManualCutCellStyle}"/>
                <DataGridTextColumn Header="Цвет" Binding="{Binding Color}" IsReadOnly="True" Width="120" ElementStyle="{StaticResource ManualCutCellStyle}"/>
                <DataGridTextColumn Header="Длина хлыста" Binding="{Binding StockLength}" IsReadOnly="True" Width="100" ElementStyle="{StaticResource ManualCutCellStyle}"/>
                <DataGridTextColumn Header="Количество хлыстов" Binding="{Binding StockCount}" IsReadOnly="True" Width="130" ElementStyle="{StaticResource ManualCutCellStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Исчезающий баллун-уведомление об успешном сохранении -->
        <Border x:Name="toast" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="16,10" Background="#EE2E7D32" CornerRadius="4"
                Opacity="0">
            <TextBlock x:Name="toastText" Text="" Foreground="White"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>