<UserControl x:Class="LinearCutWpf.Controls.ExportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnExportExcel" Content="Экспорт в Excel" Padding="10,5" Margin="0,0,10,0" Click="BtnExportExcel_Click"/>
            <TextBlock Text="Тип отчёта:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="cbReportTypePdf" Width="230" VerticalAlignment="Center" Margin="0,0,15,0" SelectedIndex="0">
                <ComboBoxItem Content="Подробный отчёт"/>
                <ComboBoxItem Content="Отчёт об использовании материалов"/>
                <ComboBoxItem Content="Визуальный отчёт"/>
            </ComboBox>
            <TextBlock Text="Коэфф. высоты:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtVisualHeightCoef" Width="50" VerticalAlignment="Center" Margin="0,0,15,0" TextChanged="txtVisualHeightCoef_TextChanged"/>
            <Button x:Name="btnExportPdf" Content="Экспорт в PDF" Padding="10,5" Click="BtnExportPdf_Click"/>
        </StackPanel>

        <!-- Таблица для выбора артикулов на выгрузку -->
        <DataGrid x:Name="dgExportData" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Background="White" HeadersVisibility="Column"
                  PreviewKeyDown="dgExportData_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="100">
                    <DataGridCheckBoxColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkSelectAll" Content="Сохранить" IsChecked="True" Click="chkSelectAll_Click"/>
                        </StackPanel>
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" IsReadOnly="True" Width="200"/>
                <DataGridTextColumn Header="Длина хлыста" Binding="{Binding StockLength}" IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="Количество хлыстов" Binding="{Binding StockCount}" IsReadOnly="True" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>