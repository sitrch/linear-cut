<UserControl x:Class="LinearCutWpf.Controls.GroupingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TabControl x:Name="groupingTabControl" TabStripPlacement="Top">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="{Binding Path=Background, RelativeSource={RelativeSource Self}}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1,1,1,0"
                                        Padding="12,6">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
        </TabControl>
        <TextBlock x:Name="hintText" 
                   Text="Для отображения группировки выберите столбцы «Ключ» и «Значение» на вкладке «Данные»"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   FontSize="14" 
                   Foreground="#888888"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="40"/>
    </Grid>
</UserControl>
