<Window x:Class="LinearCutWpf.Controls.ValidationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ошибки в данных" Height="400" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Margin="0,0,0,10" Foreground="Red" FontWeight="Bold" TextWrapping="Wrap"
                   Text="Обнаружены строки с пустыми или некорректными (не число) значениями в колонках 'Длина' или 'Количество'. Эти строки будут выделены красным в таблице."/>
        
        <DataGrid Grid.Row="1" x:Name="dgErrors" AutoGenerateColumns="True" IsReadOnly="True"
                  Background="White" Margin="0,0,0,10"
                  HeadersVisibility="Column"/>
                  
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Пропустить" Width="100" Margin="0,0,10,0" Padding="5" Click="BtnIgnore_Click"/>
            <Button Content="Отмена" Width="100" Padding="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>