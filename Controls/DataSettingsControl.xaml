<UserControl x:Class="LinearCutWpf.Controls.DataSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LinearCutWpf.Controls"
             xmlns:converters="clr-namespace:LinearCutWpf.Converters"
             Background="White">
    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="KeyCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsKey}" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ValCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVal}" Value="True">
                    <Setter Property="Background" Value="LightYellow"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="QtyCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsQty}" Value="True">
                    <Setter Property="Background" Value="LightCyan"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель настроек -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel>
                <Button x:Name="btnLoad" Content="Открыть .xlsx" Height="40" Background="AliceBlue" Click="OnOpenFileClick"/>
                <ComboBox x:Name="cbSheetSelector" Margin="0,5,0,0" Height="30" SelectionChanged="OnSheetSelected"/>

                <TextBlock Text="Настройка ролей столбцов:" Margin="0,10,0,5"/>
                <DataGrid x:Name="dgColumnConfig" Height="200" AutoGenerateColumns="False" CanUserAddRows="False"
                          CellEditEnding="OnColumnConfigCellEditEnding"
                          PreviewMouseLeftButtonDown="OnColumnConfigPreviewMouseLeftButtonDown"
                          Loaded="OnDgColumnConfigLoaded">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Столбец" Binding="{Binding ColName}" IsReadOnly="True" Width="*"/>
                        <DataGridCheckBoxColumn Header="Key" Binding="{Binding IsKey, UpdateSourceTrigger=PropertyChanged}" Width="50" CellStyle="{StaticResource KeyCell}" ElementStyle="{StaticResource CheckBoxStyle}" EditingElementStyle="{StaticResource CheckBoxStyle}"/>
                        <DataGridCheckBoxColumn Header="Value" Binding="{Binding IsVal, UpdateSourceTrigger=PropertyChanged}" Width="50" CellStyle="{StaticResource ValCell}" ElementStyle="{StaticResource CheckBoxStyle}" EditingElementStyle="{StaticResource CheckBoxStyle}"/>
                        <DataGridCheckBoxColumn Header="Quantity" Binding="{Binding IsQty, UpdateSourceTrigger=PropertyChanged}" Width="50" CellStyle="{StaticResource QtyCell}" ElementStyle="{StaticResource CheckBoxStyle}" EditingElementStyle="{StaticResource CheckBoxStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Пресеты:" Margin="0,10,0,5"/>
                <DataGrid x:Name="dgPresets" Height="150" AutoGenerateColumns="False" CanUserAddRows="False"
                          MouseRightButtonUp="OnPresetRightClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Обрезка н." Binding="{Binding TrimStart}" Width="80"/>
                        <DataGridTextColumn Header="Обрезка к." Binding="{Binding TrimEnd}" Width="80"/>
                        <DataGridTextColumn Header="Рез" Binding="{Binding CutWidth}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button x:Name="btnAddPreset" Content="Добавить пресет" Height="28" Width="150" Margin="0,5,0,0" Click="OnAddPreset"/>

                <GroupBox Header="Настройки по умолчанию" Margin="0,10,0,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Хлыст:" VerticalAlignment="Center" Margin="0,0,5,0" Grid.Row="0" Grid.Column="0"/>
                        <ComboBox x:Name="cbDefaultStock" Grid.Row="0" Grid.Column="1" SelectionChanged="OnDefaultStockChanged"/>
                        <Button x:Name="btnAddStock" Content="+" Grid.Row="0" Grid.Column="2" Width="25" Height="22" Click="OnAddStock"/>
                        <Button x:Name="btnRemoveStock" Content="−" Grid.Row="0" Grid.Column="3" Width="25" Height="22" Click="OnRemoveStock"/>

                        <TextBlock Text="Пресет:" VerticalAlignment="Center" Margin="0,5,5,0" Grid.Row="1" Grid.Column="0"/>
                        <ComboBox x:Name="cbDefaultPreset" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,5,0,0" SelectionChanged="OnDefaultPresetChanged"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Правая панель - данные -->
        <DataGrid x:Name="dgInput" Grid.Column="1" IsReadOnly="True" Background="White"
                  AutoGenerateColumns="True" LoadingRow="OnDgInputLoadingRow"
                  AutoGeneratingColumn="OnDgInputAutoGeneratingColumn"
                  Loaded="OnDgInputLoaded"/>
    </Grid>
</UserControl>