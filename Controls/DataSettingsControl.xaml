<UserControl x:Class="LinearCutWpf.Controls.DataSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LinearCutWpf.Controls"
             xmlns:converters="clr-namespace:LinearCutWpf.Converters"
             xmlns:controls="clr-namespace:LinearCutWpf.Controls"
             Background="White">
    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450" x:Name="LeftColumn"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель настроек -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel>
                <TextBlock Text="Объект:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="tbObjectName" Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                <Button x:Name="btnLoad" Content="Открыть .xlsx" Height="40" Background="AliceBlue" Click="OnOpenFileClick"/>
                <ComboBox x:Name="cbSheetSelector" Margin="0,5,0,0" Height="30" SelectionChanged="OnSheetSelected"/>

                <TextBlock Text="Пресеты:" Margin="0,10,0,5"/>
                <DataGrid x:Name="dgPresets" Height="150" AutoGenerateColumns="False" CanUserAddRows="False"
                          MouseRightButtonUp="OnPresetRightClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Обрезка н." Binding="{Binding TrimStart}" Width="80"/>
                        <DataGridTextColumn Header="Обрезка к." Binding="{Binding TrimEnd}" Width="80"/>
                        <DataGridTextColumn Header="Рез" Binding="{Binding CutWidth}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button x:Name="btnAddPreset" Content="Добавить пресет" Height="28" Width="150" Margin="0,5,0,0" Click="OnAddPreset"/>

                <GroupBox Header="Настройки по умолчанию" Margin="0,10,0,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Хлыст:" VerticalAlignment="Center" Margin="0,0,5,0" Grid.Row="0" Grid.Column="0"/>
                        <ComboBox x:Name="cbDefaultStock" Grid.Row="0" Grid.Column="1" SelectionChanged="OnDefaultStockChanged"/>
                        <Button x:Name="btnAddStock" Content="+" Grid.Row="0" Grid.Column="2" Width="25" Height="22" Click="OnAddStock"/>
                        <Button x:Name="btnRemoveStock" Content="−" Grid.Row="0" Grid.Column="3" Width="25" Height="22" Click="OnRemoveStock"/>

                        <TextBlock Text="Пресет:" VerticalAlignment="Center" Margin="0,5,5,0" Grid.Row="1" Grid.Column="0"/>
                        <ComboBox x:Name="cbDefaultPreset" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,5,0,0" SelectionChanged="OnDefaultPresetChanged"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Разделитель -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="LightGray" DragCompleted="GridSplitter_DragCompleted"/>

        <!-- Правая панель - данные -->
        <DataGrid x:Name="dgInput" Grid.Column="2" IsReadOnly="True" Background="White"
                  AutoGenerateColumns="True" LoadingRow="OnDgInputLoadingRow"
                  AutoGeneratingColumn="OnDgInputAutoGeneratingColumn"
                  Loaded="OnDgInputLoaded"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#FFD0D0D0"
                  VerticalGridLinesBrush="#FFD0D0D0">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                    <Setter Property="Background" Value="#FFF0F0F0"/>
                    <Setter Property="BorderBrush" Value="#FFD0D0D0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="4,2"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#FFD0D0D0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                </Style>
            </DataGrid.Resources>
        </DataGrid>
    </Grid>
</UserControl>