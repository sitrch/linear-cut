<UserControl x:Class="LinearCutWpf.Controls.ArticleSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LinearCutWpf.Controls"
             xmlns:converters="clr-namespace:LinearCutWpf.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ControlTemplate x:Key="BarLengthComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <ToggleButton x:Name="ToggleButton"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedItem.DisplayLength, RelativeSource={RelativeSource TemplatedParent}}"
                                       VerticalAlignment="Center"
                                       Margin="3,0,0,0"/>
                            <Path Grid.Column="1"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{TemplateBinding Foreground}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,5,0"/>
                        </Grid>
                    </ToggleButton>
                </Border>
                <Popup x:Name="PART_Popup"
                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Bottom"
                       AllowsTransparency="True">
                    <Border Background="White"
                            BorderBrush="Gray"
                            BorderThickness="1">
                        <ScrollViewer>
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="PresetComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <ToggleButton x:Name="ToggleButton"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedItem.Name, RelativeSource={RelativeSource TemplatedParent}}"
                                       VerticalAlignment="Center"
                                       Margin="3,0,0,0"/>
                            <Path Grid.Column="1"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{TemplateBinding Foreground}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,5,0"/>
                        </Grid>
                    </ToggleButton>
                </Border>
                <Popup x:Name="PART_Popup"
                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Bottom"
                       AllowsTransparency="True">
                    <Border Background="White"
                            BorderBrush="Gray"
                            BorderThickness="1">
                        <ScrollViewer>
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
            <TextBlock Text="Настройка артикулов перед раскроем" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock Text="Высота по умолчанию:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtDefaultHeight" Width="80" Height="25" VerticalContentAlignment="Center" TextChanged="OnDefaultHeightChanged"/>
        </StackPanel>

        <DataGrid x:Name="dgArticles" Grid.Row="1" Margin="10" 
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" SelectionMode="Single"
                  GridLinesVisibility="All" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleName}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ArticleDescription}" IsReadOnly="True" Width="*"/>
                <DataGridTemplateColumn Header="Видимая высота" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                             <TextBox Text="{Binding SelectedVisibleHeight, UpdateSourceTrigger=PropertyChanged}"
                                      GotFocus="OnHeightCellGotFocus"
                                      LostFocus="OnHeightCellLostFocus"
                                      TextChanged="OnHeightCellTextChanged">
                                  <TextBox.Style>
                                      <Style TargetType="TextBox">
                                          <Setter Property="Background" Value="White"/>
                                          <Style.Triggers>
                                              <DataTrigger Binding="{Binding IsDefaultValue}" Value="True">
                                                  <Setter Property="Background" Value="#E6F3FF"/>
                                              </DataTrigger>
                                              <DataTrigger Binding="{Binding IsManuallyChanged}" Value="True">
                                                  <Setter Property="Background" Value="#FFB6C1"/>
                                              </DataTrigger>
                                          </Style.Triggers>
                                      </Style>
                                  </TextBox.Style>
                             </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Кол-во деталей" Binding="{Binding TotalCount}" IsReadOnly="True" Width="120"/>

                <DataGridTemplateColumn Header="Длина хлыста" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailableStockLengths}"
                                          SelectedValue="{Binding SelectedBarLength, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="DisplayLength" SelectedValuePath="Length"
                                          SelectionChanged="OnBarLengthCellSelectionChanged"
                                          ToolTip="Выберите значение или оставьте пустым для использования длины по умолчанию">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Template" Value="{StaticResource BarLengthComboBoxTemplate}"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBarLengthDefaultValue}" Value="True">
                                                    <Setter Property="Background" Value="#E6E6E6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBarLengthManuallyChanged}" Value="True">
                                                    <Setter Property="Background" Value="#FFB6C1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>
                                <TextBlock Text="{Binding DisplayDefaultBarLength}"
                                           Foreground="#808080"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBarLengthDefaultValue}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Пресет" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailablePresets}"
                                          SelectedItem="{Binding SelectedPreset, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="OnPresetCellSelectionChanged"
                                          ToolTip="Выберите значение или оставьте пустым для использования пресета по умолчанию">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Template" Value="{StaticResource PresetComboBoxTemplate}"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPresetDefaultValue}" Value="True">
                                                    <Setter Property="Background" Value="#E6E6E6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>
                                <TextBlock Text="{Binding DisplayDefaultPresetName}"
                                           Foreground="#808080"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPresetDefaultValue}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>