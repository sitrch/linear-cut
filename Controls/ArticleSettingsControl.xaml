<UserControl x:Class="LinearCutWpf.Controls.ArticleSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LinearCutWpf.Controls"
             xmlns:converters="clr-namespace:LinearCutWpf.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
            <TextBlock Text="Настройка артикулов перед раскроем" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock Text="Высота по умолчанию:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtDefaultHeight" Width="80" Height="25" VerticalContentAlignment="Center" TextChanged="OnDefaultHeightChanged"/>
        </StackPanel>

        <DataGrid x:Name="dgArticles" Grid.Row="1" Margin="10" 
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" SelectionMode="Single"
                  GridLinesVisibility="All" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleName}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ArticleDescription}" IsReadOnly="True" Width="*"/>
                <DataGridTemplateColumn Header="Видимая высота" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                             <TextBox Text="{Binding SelectedVisibleHeight, UpdateSourceTrigger=PropertyChanged}"
                                      GotFocus="OnHeightCellGotFocus"
                                      LostFocus="OnHeightCellLostFocus"
                                      TextChanged="OnHeightCellTextChanged">
                                 <TextBox.Style>
                                     <Style TargetType="TextBox">
                                         <Setter Property="Background" Value="White"/>
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding IsDefaultValue}" Value="True">
                                                 <Setter Property="Background" Value="#E6F3FF"/>
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding IsManuallyChanged}" Value="True">
                                                 <Setter Property="Background" Value="#FFF5E6"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </TextBox.Style>
                             </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Кол-во деталей" Binding="{Binding TotalCount}" IsReadOnly="True" Width="120"/>
                
                <DataGridTemplateColumn Header="Длина хлыста" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailableStockLengths}"
                                      SelectedValue="{Binding SelectedBarLength, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Length" SelectedValuePath="Length"
                                      ToolTip="Оставьте пустым для использования длины по умолчанию"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Пресет" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=AvailablePresets}"
                                      SelectedItem="{Binding SelectedPreset, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Name"
                                      ToolTip="Оставьте пустым для использования пресета по умолчанию"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>