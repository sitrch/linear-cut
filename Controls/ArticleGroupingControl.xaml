<UserControl x:Class="LinearCutWpf.Controls.ArticleGroupingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10" Background="#F0F0F0">
            <StackPanel x:Name="leftPanel">
                <!-- Хлыст -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock x:Name="indicatorBar" Text="✓" Foreground="Green" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Label Content="Хлыст:" FontWeight="Bold"/>
                </StackPanel>
                <ComboBox x:Name="cbBarLength" Width="200" Margin="0,5,0,0"/>

                <!-- Пресет -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock x:Name="indicatorPreset" Text="✓" Foreground="Green" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Label Content="Пресет:" FontWeight="Bold"/>
                </StackPanel>
                <ComboBox x:Name="cbPreset" Width="200" Margin="0,5,0,0"/>

                <!-- Чекбокс ручного раскроя -->
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock x:Name="indicatorManual" Text="✓" Foreground="Green" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <CheckBox x:Name="chkManual" Content="Ручной раскрой" FontWeight="Bold"/>
                </StackPanel>

                <!-- ManualCutControl -->
                <Frame x:Name="manualCutFrame" Width="390" Margin="0,5,0,0"/>

                <!-- Ошибки ручного раскроя -->
                <Border x:Name="errorsBorder" Width="390" Margin="0,5,0,0"
                        BorderBrush="Red" BorderThickness="1" CornerRadius="3"
                        Padding="5" Background="#FFF5F5" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠ Ошибки ручного раскроя:" FontWeight="Bold" Foreground="Red" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtDetailErrors" Foreground="DarkRed" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Info label -->
                <TextBlock x:Name="infoLabel" Width="390" Margin="0,10,0,0"
                           FontFamily="Consolas" FontSize="12" Foreground="Black" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Правая панель с деталями -->
        <DataGrid Grid.Column="1" x:Name="gridDetails"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Background="White"/>
    </Grid>
</UserControl>