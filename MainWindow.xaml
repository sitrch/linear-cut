<Window x:Class="LinearCutWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LinearCutWpf.Controls"
        Title="Linear Cut Optimizer" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Стиль для заголовка таба -->
        <Style x:Key="TabHeaderStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="tabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1,1,1,1"
                                CornerRadius="6,6,0,0"
                                Margin="2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" 
                                            HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter TargetName="tabBorder" Property="Margin" Value="2,0,2,-1"/>
                                <Setter TargetName="tabBorder" Property="Background" Value="LightBlue"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="tabBorder" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
<TabControl x:Name="tabControl" TabStripPlacement="Top" 
                    SelectionChanged="TabControl_SelectionChanged"
                    ItemContainerStyle="{StaticResource TabHeaderStyle}"
                    Background="White">
<TabItem Header="Данные">
                <controls:DataSettingsControl x:Name="dataSettingsControl"/>
            </TabItem>
            <TabItem Header="Настройка артикулов">
                <controls:ArticleSettingsControl x:Name="articleSettingsControl"/>
            </TabItem>
            <TabItem Header="Группировка">
                <controls:GroupingControl x:Name="groupingControl"/>
            </TabItem>
            <TabItem Header="Раскрой">
                <controls:ResultsControl x:Name="resultsControl"/>
            </TabItem>
            <TabItem Header="Сохранение">
                <controls:ExportControl x:Name="exportControl"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
